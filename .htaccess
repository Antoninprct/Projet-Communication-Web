DirectoryIndex index.php
RewriteEngine On

RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

RewriteRule ^$ index.php [L,QSA]
RewriteRule ^auth/?$ pages/auth.php [L,QSA]
RewriteRule ^products/?$ pages/products.php [L,QSA]
RewriteRule ^products/([0-9]+)/?$ pages/product.php?id=$1 [L,QSA]
